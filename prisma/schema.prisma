generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          String   @id @default(cuid())
  barcode     String?  @unique
  name        String
  brand       String?
  carbsPer100 Float
  kcalPer100  Float?
  source      String   // "openfoodfacts" | "manual"
  createdAt   DateTime @default(now())
  entries     Entry[]
}

model Entry {
  id        String   @id @default(cuid())
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  // for one-off manual entries with no saved product
  customName String?
  customCarbsPer100 Float?
  amountGrams Float
  carbsTotal  Float    // computed at save time, so historic entries don't shift if a product's data is edited later
  loggedAt    DateTime @default(now())
  mealType    String?  // breakfast/lunch/dinner/snack, optional
}