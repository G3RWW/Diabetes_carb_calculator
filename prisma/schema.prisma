generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  createdAt DateTime @default(now())
  products Product[]
  entries Entry[]
}
model Product {
  id          String   @id @default(cuid())
  barcode     String?  @unique
  name        String
  brand       String?
  carbsPer100 Float
  kcalPer100  Float?
  source      String   // "openfoodfacts" | "manual"
  userId     String? //null = benras | set = vartotojo sukurtas (null = shared | set = user created)
  user       User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  entries     Entry[]
}

model Entry {
  id        String   @id @default(cuid())
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  customName String?
  customCarbsPer100 Float?
  amountGrams Float
  carbsTotal  Float
  loggedAt    DateTime @default(now())
  mealType    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}
